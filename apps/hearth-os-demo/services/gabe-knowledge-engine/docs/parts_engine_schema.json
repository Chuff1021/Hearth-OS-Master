{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PartsEngineManualAnswer",
  "type": "object",
  "required": [
    "answer",
    "source_type",
    "manual_title",
    "page_number",
    "source_url",
    "quote",
    "confidence",
    "certainty"
  ],
  "properties": {
    "answer": { "type": "string" },
    "source_type": { "const": "manual" },
    "manual_title": { "type": "string" },
    "page_number": { "type": "integer", "minimum": 1 },
    "source_url": { "type": "string", "format": "uri" },
    "quote": { "type": "string", "minLength": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
    "certainty": {
      "type": "string",
      "enum": ["Verified Exact", "Verified Partial", "Interpreted", "Unverified"]
    },
    "validator_notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
